[ui]
username = Chris Guilbeau <cguilbeau@zogotech.com>
merge = kdiff3
#merge = ksmerge
ssh = ssh -C

[extensions]
purge=
hgext.extdiff =

[merge-tools]
ksmerge.executable = /usr/local/bin/ksdiff
ksmerge.args = --merge --output $output --base $base -- $other $local
kdiff3.args = $base $other $local -o $output

[extdiff]
cmd.kdiff3 =
cmd.ksdiff =
opts.ksdiff = --changeset --wait --filelist
cmd.vdiff = vim
opts.vdiff = -f '+next' '+execute "DirDiff" fnameescape(argv(0)) fnameescape(argv(1))'


[paths]
alpha/appserver = ssh://cg@austin.zogotech.com/hg-repo/alpha/appserver
alpha/server = ssh://cg@austin.zogotech.com/hg-repo/alpha/server
alpha/webserver = ssh://cg@austin.zogotech.com/hg-repo/alpha/webserver
beta/appserver = ssh://cg@austin.zogotech.com/hg-repo/beta/appserver
beta/server = ssh://cg@austin.zogotech.com/hg-repo/beta/server
beta/webserver = ssh://cg@austin.zogotech.com/hg-repo/beta/webserver
stable/appserver = ssh://cg@austin.zogotech.com/hg-repo/stable/appserver
stable/server = ssh://cg@austin.zogotech.com/hg-repo/stable/server
stable/webserver = ssh://cg@austin.zogotech.com/hg-repo/stable/webserver

[slack_notify]
baseurl = http://zlinux.ztaustin.local:8000/hg
basepath = /Users

[hooks]
# changegroup.slack= python:/Users/chrisguilbeau/z/hg/slack/postmessage.py:notify
