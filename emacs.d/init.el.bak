;;                  :candidates-process
;;                  (lambda ()
;;                    (start-file-process "my-process" "foo" "echo test")))
;;       :buffer "*helm async source*")
;; (setq my-source (shell-command-to-string "/apps/ripgrep/rg.exe --files --follow"))
(defun cg-h1 ()
  (interactive)
  (helm :sources 'my-source
	:buffer "*helm my command*"))
(defun cg-h2 ()
  (interactive)
  (helm :sources (helm-build-async-source "test2"
		   :candidates-process
		   (lambda () (start-process "echo" nil "echo" "a\nb\nc")))
	:buffer "*helm my command*"))

;; emacs things
(setq backup-inhibited t);disable backup
(setq auto-save-default nil);disable auto save
(setq large-file-warning-threshold nil) ;; no more large file warnings
(setq ring-bell-function (lambda() (message "*beep*"))) ;; don't ring bell
(tool-bar-mode -1)
(scroll-bar-mode -1)
(setq mode-require-final-newline t) ;; newline at end of document
(custom-set-faces
 ;; custom-set-faces was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(default ((t (:family "Consolas" :foundry "outline" :slant normal :weight normal :height 98 :width normal)))))
