syntax on "syntax highlighting
set nowmnu
set wildmode=full
" set hlsearch " highlight search
set autoindent "indent to the previous level
filetype indent off
filetype plugin on "make commands smarter for your file ]m and the like
set clipboard=unnamed " set clipboard to system clipboard (gui compile req)
set backspace=2 " make backspace behave correctly!
set incsearch "jump to first match when searching
set tags=tags;/ "search for a tags file recursively till it finds one
set cc=72,79 "put a line for comments and end of code pep8
set expandtab shiftwidth=4 softtabstop=4
set tabstop=4
autocmd BufWritePre * :%s/\s\+$//e "delete trailing whitespace on save
set number " show line numbers
" set relativenumber " show the relative numbers
set autoread " automatically read files when changed by another editor
set hidden " just hide the buffer till I come back to it
set ignorecase " ignore case while searching
set wildignore+=*/.git/*,*/.hg/*,*.pyc,*.DS_Store "don't pick up certain things
set nofoldenable " no code folding ever!!!
" set path=.\**
" set path=$PWD/**
set noswapfile
set nobackup
set complete=.,w,b,u,t "removed 'i' which scans all files in path
set completeopt=
set t_Co=256
set iskeyword+=\-

" Solarized
" colors solarized
" let g:solarized_italic=0
" let g:solarized_termcolors = 16
" let g:solarized_visibility = "high"
" let g:solarized_contrast = "high"
" set bg=dark

" Set extra options when running in GUI mode
if has("gui_running")
    set guioptions-=T
    set guioptions+=e
    set t_Co=256
    " set guifont=Vera Sans Mono:h11
    set guicursor=a:blinkon0
    colors solarized
    let g:solarized_italic=0
endif

" lightline
" let g:lightline={'colorscheme': 'solarized_light'}

" status line
set laststatus=2                                "always show status line
set statusline=\                                " start it off
set statusline+=%f\                             "File+path
set statusline+=%y\                             "FileType
set statusline+=[%{&ff}]\                       "FileFormat (dos/unix..)
set statusline+=%m%r%w\                         "Modified? Readonly? Top/bot.
set statusline+=%#warningmsg#
set statusline+=%{SyntasticStatuslineFlag()}
set statusline+=%*
set statusline +=%=%5l                          "current line
set statusline +=/%L\ \                         "total lines

" status line color change
hi StatusLine term=None ctermfg=252 ctermbg=238
hi StatusLineNC term=None ctermfg=255 ctermbg=243
hi VertSplit term=None ctermfg=white ctermbg=243

" syntastic
let g:syntastic_python_checkers = ['pyflakes']
let g:syntastic_javascript_checkers = ['jshint']
let g:syntastic_check_on_open = 1

" CtrlP setup
let g:ctrlp_follow_symlinks = 1 "follow symlinks into the darkness
let g:ctrlp_extensions = ['tag'] "enable searching of tags
let g:ctrlp_working_path_mode = 0
let g:ctrlp_use_caching = 0

" dirdiff setup
let g:DirDiffExcludes = ".hg,tags,*.pyc,.*.swp,.DS_Store"
set diffopt+=context:99999
let g:DirDiffEnableMappings = 1
highlight DiffAdd    cterm=bold ctermfg=none ctermbg=194 gui=none guifg=bg guibg=Red
highlight DiffDelete cterm=bold ctermfg=217 ctermbg=224 gui=none guifg=bg guibg=Red
highlight DiffChange cterm=bold ctermfg=none ctermbg=189 gui=none guifg=bg guibg=Red
highlight DiffText   cterm=bold ctermfg=none ctermbg=229 gui=none guifg=bg guibg=Red
"
" custom functions...
function! NumberToggle()
    if (&relativenumber == 1)
        set norelativenumber
        set number
    elseif(&number == 1)
        set norelativenumber
        set nonumber
    else
        set number
        set relativenumber
    endif
endfunc

