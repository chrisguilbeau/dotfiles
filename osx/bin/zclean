#! /usr/bin/env python
from os import walk
from os.path import join
from subprocess import Popen
from subprocess import PIPE

def getCommand(path):
    return ' && '.join((
        'pushd "{}"'.format(path),
        'zhg diff',
        ))

def isDirty(path):
    def getOuput():
        return Popen(
            getCommand(path), shell=True, stdout=PIPE).stdout.read()
    return len(getOuput().split('\n')) != 5

def getDirtyFolders(path):
    root, folders, _ = walk(path).next()
    for folder in folders:
        def getMarker():
            return 'dirty' if isDirty(join(root, folder)) else 'clean'
        yield '{} {}'.format(getMarker(), folder)

for folder in getDirtyFolders('.'):
    print folder
