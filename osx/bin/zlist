#!/usr/bin/env python
import os
import time

projPath = '/Users/cg/z/proj'

class ProjDir(object):
    def __init__(self, name, path):
        self.name = name
        self.path = path
        # self.sortTime = sortTime
        # self.displayTime = displayTime
        self.sortTime = max(map(
            lambda x: os.path.getmtime(x[0]), os.walk(path)))
        self.displayTime = time.ctime(self.sortTime)

def getDirs(path=projPath):
    for o in os.listdir(path):
        opath = os.path.join(path, o)
        if os.path.isdir(opath):
            if o not in ['current']:
                yield ProjDir(o, opath)

def main():
    dirs = list(reversed(sorted(getDirs(), key=lambda a: a.sortTime)))
    for i, d in enumerate(dirs):
        print '{} {} {}'.format(
            i,
            d.name.ljust(30),
            d.displayTime,
            )
    print
    print 'project number:',
    selDir = raw_input()
    try:
        os.system('zswitch {}'.format(dirs[int(selDir)].name))
    except:
        print 'invalid option!'

if __name__ == '__main__':
    main()
