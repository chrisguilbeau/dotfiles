export PATH="~/bin:/usr/local/bin:$PATH"
export CLICOLOR=1
export GREP_COLOR="auto"
export PS1="\[\e[0;35m\]\u@\h:\[\e[0;34m\]\w\$ \[\e[m\]"
export EDITOR=vim

alias zz="cd ~/z/proj/"\`z?\`

